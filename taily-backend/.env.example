# Local backend environment (DO NOT commit real secrets)
#
# Copy to `taily-backend/.env` for local development.
# The backend will read it automatically on startup.

# Enable/disable OpenAI-backed behavior.
OPENAI_ENABLED=true

# Required when OPENAI_ENABLED=true
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Optional model knobs
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=dall-e-2
OPENAI_PORTRAIT_SIZE=512x512

